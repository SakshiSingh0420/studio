
{
  "entities": {
    "Country": {
      "title": "Country",
      "type": "object",
      "description": "Represents a sovereign country with economic and market metadata.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "region": { "type": "string" },
        "incomeGroup": { "type": "string", "enum": ["Advanced", "Emerging", "Frontier"] },
        "currency": { "type": "string" },
        "population": { "type": "number", "description": "Population in millions" },
        "nominalGdp": { "type": "number", "description": "Nominal GDP in USD billions" },
        "gdpPerCapita": { "type": "number", "description": "GDP per capita in USD" },
        "inflation": { "type": "number", "description": "Annual inflation rate percentage" },
        "dataYear": { "type": "number", "description": "The year the data represents" },
        "primaryDataSource": { "type": "string", "enum": ["IMF", "World Bank", "National Source", "Manual"] },
        "equityIndex": { "type": "string", "description": "Representative equity index name" },
        "bondYield10Y": { "type": "number", "description": "10-year government bond yield percentage" },
        "fxRate": { "type": "number", "description": "Exchange rate vs USD" },
        "scenarioName": { "type": "string", "description": "Current analytical cycle or scenario name" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "region", "dataYear", "nominalGdp", "population"]
    },
    "Parameter": {
      "title": "Parameter",
      "type": "object",
      "description": "Definition of a rating factor.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Economic", "Fiscal", "External", "Monetary", "Institutional", "ESG"] },
        "type": { "type": "string", "enum": ["raw", "derived"] },
        "formula": { "type": "string", "description": "Formula for derived parameters (e.g., debt/gdp)" },
        "dataSource": { "type": "string" },
        "frequency": { "type": "string", "enum": ["Annual", "Quarterly", "Monthly"] }
      },
      "required": ["name", "category", "type"]
    },
    "RatingModel": {
      "title": "Rating Model",
      "type": "object",
      "description": "A weighted collection of parameters with version control.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "number" },
        "isActive": { "type": "boolean" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "parentModelId": { "type": "string" },
        "weights": { 
          "type": "object",
          "description": "Map of parameterId to weight percentage"
        },
        "transformations": {
          "type": "object",
          "description": "Thresholds for scoring parameters 1-5"
        }
      },
      "required": ["name", "weights", "version", "status", "isActive"]
    },
    "RatingScale": {
      "title": "Rating Scale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mapping": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "minScore": { "type": "number" },
              "maxScore": { "type": "number" },
              "rating": { "type": "string" }
            }
          }
        }
      }
    },
    "Rating": {
      "title": "Rating",
      "type": "object",
      "properties": {
        "countryId": { "type": "string" },
        "modelId": { "type": "string" },
        "scaleId": { "type": "string" },
        "finalScore": { "type": "number" },
        "initialRating": { "type": "string" },
        "approvalStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "isSandbox": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/countries/{countryId}": { "schema": "Country", "description": "Sovereign list" },
    "/parameters/{paramId}": { "schema": "Parameter", "description": "Parameter Master" },
    "/models/{modelId}": { "schema": "RatingModel", "description": "Analytical models" },
    "/scales/{scaleId}": { "schema": "RatingScale", "description": "Rating scales" },
    "/ratings/{ratingId}": { "schema": "Rating", "description": "Rating sessions" },
    "/factSheets/{countryId}": { "schema": "object", "description": "Raw values per country" }
  }
}
