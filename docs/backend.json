{
  "entities": {
    "Country": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Country",
      "type": "object",
      "description": "Represents a sovereign country with its key demographic and economic data.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Country entity."
        },
        "name": {
          "type": "string",
          "description": "Official name of the country."
        },
        "region": {
          "type": "string",
          "description": "Geographical region the country belongs to (e.g., 'Europe', 'Asia')."
        },
        "incomeGroup": {
          "type": "string",
          "description": "World Bank income group classification (e.g., 'High income', 'Low income')."
        },
        "currency": {
          "type": "string",
          "description": "Official currency of the country."
        },
        "population": {
          "type": "number",
          "description": "Total population of the country."
        },
        "gdp": {
          "type": "number",
          "description": "Gross Domestic Product of the country (in billions USD)."
        }
      },
      "required": [
        "name",
        "region",
        "gdp"
      ]
    },
    "Rating": {
      "title": "Rating",
      "type": "object",
      "properties": {
        "countryId": { "type": "string" },
        "finalScore": { "type": "number" },
        "initialRating": { "type": "string" },
        "approvalStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/countries/{countryId}": {
      "schema": { "$ref": "#/entities/Country" },
      "description": "Sovereign entities list."
    },
    "/ratings/{ratingId}": {
      "schema": { "$ref": "#/entities/Rating" },
      "description": "Historical rating sessions."
    }
  }
}